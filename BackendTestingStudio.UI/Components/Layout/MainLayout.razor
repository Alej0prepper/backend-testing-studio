@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavManager

<div class="shell">
    <aside class="sidebar">
        <div class="brand">
            <div class="brand-mark">BTS</div>
            <div class="brand-copy">
                <span class="brand-kicker">Backend Testing Studio</span>
                <span class="brand-title">Request lab</span>
                <span class="brand-subtitle">Environments, API Explorer, History y escenarios.</span>
            </div>
        </div>

        <div class="sidebar-intro">
            <span class="sidebar-intro-label">Workspace</span>
            <strong>Local development</strong>
            <p>Explora, repite y audita requests con persistencia SQLite.</p>
        </div>

        <nav class="nav">
            @foreach (var item in NavigationItems)
            {
                <NavLink href="@item.Href"
                         class="nav-item"
                         ActiveClass="active"
                         Match="@item.Match">
                    <span class="nav-label">@item.Label</span>
                    <span class="nav-chevron">›</span>
                </NavLink>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="status-card">
                <span class="status-kicker">Platform status</span>
                <span class="status-value">Shell ready</span>
                <span class="status-detail">Core, storage and HTTP engine connected.</span>
            </div>
        </div>
    </aside>

    <div class="workspace">
        <header class="topbar">
            <div class="topbar-copy">
                <span class="topbar-kicker">Workspace</span>
                <h1>@CurrentSection</h1>
                <p class="topbar-description">@CurrentDescription</p>
            </div>

            <div class="topbar-actions">
                <div class="search-pill" role="button" tabindex="0">
                    <span class="search-icon">⌕</span>
                    <span>Search workspace</span>
                </div>
                <div class="environment-pill"><span class="dot"></span><span>Local</span></div>
                <div class="profile-pill">AT</div>
            </div>
        </header>

        <main class="content">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private readonly NavigationItem[] NavigationItems =
    [
        new("/", "Dashboard", NavLinkMatch.All),
        new("/environments", "Environments", NavLinkMatch.Prefix),
        new("/api-explorer", "API Explorer", NavLinkMatch.Prefix),
        new("/payloads", "Payloads", NavLinkMatch.Prefix),
        new("/scenarios", "Scenarios", NavLinkMatch.Prefix),
        new("/history", "History", NavLinkMatch.Prefix),
        new("/reports", "Reports", NavLinkMatch.Prefix),
        new("/settings", "Settings", NavLinkMatch.Prefix),
        new("/plugins", "Plugins", NavLinkMatch.Prefix)
    ];

    private string CurrentSection => ResolveSection();
    private string CurrentDescription => ResolveDescription();

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private string ResolveSection()
    {
        var path = NavManager.ToBaseRelativePath(NavManager.Uri).TrimEnd('/');
        if (string.IsNullOrWhiteSpace(path))
        {
            return "Dashboard";
        }

        return path switch
        {
            "environments" => "Environments",
            "api-explorer" => "API Explorer",
            "payloads" => "Payloads",
            "scenarios" => "Scenarios",
            "history" => "History",
            "reports" => "Reports",
            "settings" => "Settings",
            "plugins" => "Plugins",
            _ => "Dashboard"
        };
    }

    private string ResolveDescription()
    {
        var section = ResolveSection();
        return section switch
        {
            "Dashboard" => "Estado general del producto y accesos rápidos a las piezas principales.",
            "Environments" => "Administra variables, headers y bases URL reutilizables.",
            "API Explorer" => "Construye requests HTTP sin tocar HttpClient directamente.",
            "Payloads" => "Gestiona JSON reutilizables para API Explorer.",
            "History" => "Consulta el log de requests y repite ejecuciones guardadas.",
            "Scenarios" => "Prepara secuencias de requests para flujos repetibles.",
            "Reports" => "Observa resultados agregados y fallos recurrentes.",
            "Settings" => "Configura el comportamiento global de la herramienta.",
            "Plugins" => "Revisa los plugins instalados y su metadata.",
            _ => "Navegación principal del workspace."
        };
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= HandleLocationChanged;
    }

    private sealed record NavigationItem(string Href, string Label, NavLinkMatch Match);
}
