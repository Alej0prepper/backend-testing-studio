{
  "id": "auth",
  "name": "Auth",
  "description": "Authentication endpoints for DummyJSON.",
  "basePath": "",
  "tags": [
    "auth",
    "login"
  ],
  "defaultHeaders": {
    "Content-Type": "application/json",
    "Accept": "application/json"
  },
  "endpoints": [
    {
      "id": "login",
      "method": "POST",
      "path": "/auth/login",
      "name": "Login",
      "description": "Authenticate a DummyJSON user and capture access and refresh tokens.",
      "module": "auth",
      "tags": [
        "auth"
      ],
      "request": {
        "mode": "payload",
        "payload": "login-request"
      },
      "payload": "login-request",
      "assertions": [
        "status-ok",
        "access-token-present",
        "username-matches"
      ],
      "saveVariables": [
        {
          "name": "AccessToken",
          "source": "JsonPath",
          "jsonPath": "$.accessToken",
          "required": true
        },
        {
          "name": "RefreshToken",
          "source": "JsonPath",
          "jsonPath": "$.refreshToken",
          "required": true
        },
        {
          "name": "UserId",
          "source": "JsonPath",
          "jsonPath": "$.id",
          "required": true
        }
      ],
      "expectedStatusCodes": [
        200
      ]
    },
    {
      "id": "get-auth-user",
      "method": "GET",
      "path": "/auth/me",
      "name": "Get auth user",
      "description": "Get the current user by sending the captured access token as bearer auth.",
      "module": "auth",
      "tags": [
        "auth",
        "users"
      ],
      "headers": {
        "Authorization": "Bearer {{AccessToken}}"
      },
      "assertions": [
        "status-ok",
        "user-id-matches"
      ],
      "expectedStatusCodes": [
        200
      ]
    }
  ]
}
