{
  "id": "pet-create",
  "description": "JSON body for creating a Swagger PetStore pet.",
  "contentType": "application/json",
  "variables": [
    "PetId",
    "PetName",
    "PetStatus"
  ],
  "content": {
    "id": "{{PetId}}",
    "category": {
      "id": 1,
      "name": "dogs"
    },
    "name": "{{PetName}}",
    "photoUrls": [
      "https://example.com/backend-testing-studio/pet.png"
    ],
    "tags": [
      {
        "id": 1,
        "name": "backend-testing-studio"
      }
    ],
    "status": "{{PetStatus}}"
  },
  "examples": [
    {
      "name": "Default PetStore pet",
      "variables": {
        "PetId": "987654321",
        "PetName": "BTS Dog",
        "PetStatus": "available"
      }
    }
  ]
}
